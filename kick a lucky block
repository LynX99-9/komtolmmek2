local player = game:GetService("Players").LocalPlayer
local link = "https://discord.gg/Ggrqtyn9RW"

wait(2)

local copied = false

pcall(function()
    if setclipboard then
        setclipboard(link)
        copied = true
    end
end)

local msg = "Cyraa Still update, join my discord for more information\n"..link

if copied then
    msg = msg .. "\n\n(Link has been copied to clipboard)"
else
    msg = msg .. "\n\n(Copy failed / not supported executor)"
end

player:Kick(msg)
